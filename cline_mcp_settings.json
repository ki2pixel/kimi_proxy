    "docs-mcp-server": {
      "type": "streamableHttp",
      "url": "http://localhost:6280/mcp",
      "env": {
        "GOOGLE_API_KEY": "hidden",
        "DOCS_MCP_EMBEDDING_MODEL": "gemini:embedding-001"
