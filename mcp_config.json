        "KIMI_MCP_TOOL_PRUNING_TIMEOUT_MS": "1500",
        "KIMI_MCP_TOOL_PRUNING_MAX_CHARS_FALLBACK": "0",
        "KIMI_MCP_PRUNING_GOAL_HINT": "compress tool output",
        "KIMI_MCP_TOOL_PRUNING_MAX_PRUNE_RATIO": "0.55",
        "KIMI_MCP_TOOL_PRUNING_MIN_KEEP_LINES": "40",
        "KIMI_MCP_TOOL_PRUNING_ANNOTATE_LINES": "true",
        "KIMI_MCP_TOOL_PRUNING_INCLUDE_MARKERS": "true",
