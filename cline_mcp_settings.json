{
  "mcpServers": {
    "filesystem-agent": {
      "timeout": 60,
      "command": "python3",
      "args": [
        "/home/kidpixel/kimi-proxy/scripts/mcp_bridge.py",
        "filesystem-agent"
      ],
      "env": {
        "PATH": "/usr/bin:/bin:/usr/local/bin",
        "MCP_BRIDGE_PATH_ENV": "/usr/bin:/bin:/usr/local/bin",
        "MCP_FILESYSTEM_ALLOWED_ROOT": "/home/kidpixel",
        "MCP_BRIDGE_MONITORING_ENABLED": "1",
        "MCP_BRIDGE_MONITORING_LOG_PATH": "/tmp/kimi-proxy/mcp-bridge-filesystem.jsonl",
        "MCP_BRIDGE_MONITORING_QUEUE_MAX": "1000",
        "MCP_BRIDGE_MONITORING_SUMMARY_ON_EXIT": "1",
        "KIMI_MCP_TOOL_PRUNING_ENABLED": "1",
        "KIMI_MCP_TOOL_PRUNING_MIN_CHARS": "4000",
        "KIMI_MCP_TOOL_PRUNING_TIMEOUT_MS": "1500",
        "KIMI_MCP_TOOL_PRUNING_MAX_CHARS_FALLBACK": "0",
        "KIMI_MCP_PRUNING_GOAL_HINT": "compress tool output",
        "KIMI_MCP_TOOL_PRUNING_MAX_PRUNE_RATIO": "0.55",
        "KIMI_MCP_TOOL_PRUNING_MIN_KEEP_LINES": "40",
        "KIMI_MCP_TOOL_PRUNING_ANNOTATE_LINES": "true",
        "KIMI_MCP_TOOL_PRUNING_INCLUDE_MARKERS": "true",
        "KIMI_MCP_PRUNER_RPC_URL": "http://localhost:8006/rpc",
        "KIMI_MCP_TOOL_PRUNING_METRICS_STDERR": "1",
        "KIMI_MCP_TOOL_PRUNING_METRICS_STDERR_INTERVAL_S": "10",
        "KIMI_MCP_TOOL_PRUNING_METRICS_HEALTH": "1"
      },
      "type": "stdio",
      "autoApprove": [
        "write_file",
        "read_text_file",
        "list_directory_with_sizes",
        "list_allowed_directories",
        "directory_tree"
      ]
    },
