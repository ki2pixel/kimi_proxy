# Kimi Proxy Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# ============================================
# REQUIRED API KEYS (Main providers)
# ============================================

# Kimi Code (Primary provider - Required)
KIMI_API_KEY="your_kimi_api_key_here"

# NVIDIA (Kimi models - Required)
NVIDIA_API_KEY="your_nvidia_api_key_here"

# Mistral AI (Primary models - Required)
MISTRAL_API_KEY="your_mistral_api_key_here"

# ============================================
# OPTIONAL API KEYS (Free tiers available)
# ============================================

# OpenRouter (Multi-provider aggregation)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# SiliconFlow (Free credits available)
SILICONFLOW_API_KEY="your_siliconflow_api_key_here"

# Groq (Ultra-fast inference, free tier)
GROQ_API_KEY="your_groq_api_key_here"

# Cerebras (Free tier available)
CEREBRAS_API_KEY="your_cerebras_api_key_here"

# Google Gemini (Free tier available)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# ============================================
# MCP SERVERS (Optional - for advanced features)
# ============================================

# Qdrant Vector Database (for semantic search and memory)
QDRANT_API_KEY="your_qdrant_api_key_here"

# ============================================
# DEVELOPMENT & INTEGRATION (Optional)
# ============================================

# GitHub (for import/export features)
GITHUB_API_KEY="your_github_token_here"

# Perplexity (for research capabilities)
PERPLEXITY_API_KEY="your_perplexity_key_here"

# ============================================
# LEGACY SUPPORT (Optional)
# ============================================

# Anthropic (for Claude models)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# OpenAI (for GPT models)
OPENAI_API_KEY="your_openai_api_key_here"

# xAI (for Grok models)
XAI_API_KEY="your_xai_api_key_here"

# Azure OpenAI (requires custom endpoint)
AZURE_OPENAI_API_KEY="your_azure_openai_key_here"

# ============================================
# MCP PRUNER (Optional - for text pruning features)
# ============================================

# Pruning backend selection (heuristic | deepinfra)
KIMI_PRUNING_BACKEND="heuristic"

# DeepInfra for cloud-enhanced pruning (required if backend=deepinfra)
DEEPINFRA_API_KEY="your_deepinfra_api_key_here"
DEEPINFRA_ENDPOINT_URL="https://api.deepinfra.com/v1/inference/Qwen/Qwen3-Reranker-0.6B"
DEEPINFRA_TIMEOUT_MS="20000"
DEEPINFRA_MAX_DOCS="128"

# Pruner server configuration
MCP_PRUNER_HOST="localhost"
MCP_PRUNER_PORT="8006"
MCP_PRUNER_MAX_INPUT_CHARS="100000"
MCP_PRUNER_PRUNE_ID_TTL_S="3600"
MCP_PRUNER_CACHE_TTL_S="30"
MCP_PRUNER_CACHE_MAX_ITEMS="256"